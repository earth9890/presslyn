{
  "$schema": "https://presslyn.dev/theme.schema.json",
  "version": 1,
  "settings": {
    "color": {
      "background": "#f7f7f2",
      "foreground": "#17212b",
      "muted": "#596576",
      "accent": "#2563eb",
      "border": "#d9dee8",
      "surface": "#ffffff",
      "darkBackground": "#0f1720",
      "darkForeground": "#e7edf5",
      "darkMuted": "#a1afc2",
      "darkAccent": "#60a5fa",
      "darkBorder": "#243244",
      "darkSurface": "#16202b"
    },
    "typography": {
      "bodyFont": "ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", sans-serif",
      "headingFont": "Georgia, \"Times New Roman\", serif"
    },
    "layout": {
      "contentWidth": "52rem",
      "wideWidth": "72rem",
      "shellStyle": "tinted"
    },
    "presentation": {
      "variant": "editorial"
    }
  },
  "templateParts": {
    "header": {
      "layout": "split",
      "showDescription": true,
      "showSearch": true
    },
    "footer": {
      "layout": "columns",
      "tagline": "Discovered from content/themes at runtime."
    }
  },
  "templates": {
    "index": {
      "frame": "card",
      "cardStyle": "feature",
      "hero": "site-intro"
    },
    "single": {
      "frame": "card"
    },
    "page": {
      "frame": "card"
    },
    "archive": {
      "frame": "card",
      "cardStyle": "feature"
    },
    "category": {
      "frame": "card",
      "cardStyle": "feature"
    },
    "tag": {
      "frame": "card",
      "cardStyle": "feature"
    },
    "author": {
      "frame": "card",
      "cardStyle": "feature"
    },
    "search": {
      "frame": "card",
      "cardStyle": "feature"
    },
    "404": {
      "frame": "card"
    }
  },
  "styleVariations": [
    {
      "id": "ocean",
      "label": "Ocean",
      "accent": "#2563eb"
    },
    {
      "id": "spruce",
      "label": "Spruce",
      "accent": "#0f766e"
    }
  ]
}
